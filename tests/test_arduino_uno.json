    { "ref": "U2", "type": "ic", "value": "ATmega328P", "package": "DIP-28", "purpose": "Main microcontroller", "specs": { "pin_count": 28, "vcc_min": "1.8V", "vcc_max": "5.5V", "pinout": "1:PC6/RESET 2:PD0 3:PD1 4:PD2 5:PD3 6:PD4 7:VCC 8:GND 9:PB6/XTAL1 10:PB7/XTAL2 11:PD5 12:PD6 13:PD7 14:PB0 15:PB1 16:PB2 17:PB3/MOSI 18:PB4/MISO 19:PB5/SCK 20:AVCC 21:AREF 22:GND 23:PC0 24:PC1 25:PC2 26:PC3 27:PC4 28:PC5" } },
