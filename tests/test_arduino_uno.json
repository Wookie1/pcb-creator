{
  "project_name": "arduino_uno",
  "description": "Arduino Uno-style development board: ATmega328P microcontroller with 16MHz crystal, LM7805 voltage regulator, power LED, user LED on PB5, reset button with pull-up, ICSP header, and digital/analog pin headers. Powered by barrel jack (7-12V input).",
  "power": {
    "voltage": "5V",
    "source": "Barrel jack via LM7805 regulator, 7-12V input"
  },
