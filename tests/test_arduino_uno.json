    { "ref": "C6", "type": "capacitor", "value": "100nF", "package": "0805", "purpose": "Decoupling for U2 VCC (pin 7)", "specs": { "voltage_rating": "16V", "type": "ceramic" } },
    { "ref": "C7", "type": "capacitor", "value": "100nF", "package": "0805", "purpose": "Decoupling for U2 AVCC (pin 20)", "specs": { "voltage_rating": "16V", "type": "ceramic" } },
