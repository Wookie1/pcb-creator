    { "ref": "R2", "type": "resistor", "value": "1kohm", "package": "0805", "purpose": "Current-limiting resistor for power LED D1" },
    { "ref": "R3", "type": "resistor", "value": "1kohm", "package": "0805", "purpose": "Current-limiting resistor for user LED D2" },
    { "ref": "D1", "type": "led", "value": "green", "package": "0805", "purpose": "Power indicator LED", "specs": { "vf": "3.2V", "if": "5mA", "color": "green" } },
    { "ref": "D2", "type": "led", "value": "yellow", "package": "0805", "purpose": "User LED on PB5 (Arduino pin 13)", "specs": { "vf": "2.0V", "if": "5mA", "color": "yellow" } },
    { "ref": "SW1", "type": "switch", "value": "pushbutton", "package": "6mm_tactile", "purpose": "Reset button" },
