      "pins": ["U1.ENA", "J4.1"]
    },
    {
      "net_name": "IN1",
      "net_class": "signal",
      "pins": ["U1.IN1", "J4.2"]
    },
    {
      "net_name": "IN2",
      "net_class": "signal",
      "pins": ["U1.IN2", "J4.3"]
    },
    {
      "net_name": "IN3",
      "net_class": "signal",
      "pins": ["U1.IN3", "J4.4"]
    },
    {
      "net_name": "IN4",
      "net_class": "signal",
      "pins": ["U1.IN4", "J4.5"]
    },
    {
      "net_name": "ENB",
