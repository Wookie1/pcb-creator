{
  "project_name": "test_soil_moisture",
  "description": "Soil moisture sensor board with LM393 dual comparator, potentiometer for threshold adjust, power LED, digital output LED, analog and digital output headers",
  "power": {
    "voltage": "3.3V",
    "source": "Pin header from host MCU"
  },
  "components": [
    {
      "ref": "U1",
      "type": "ic",
      "value": "LM393",
      "package": "SOIC-8",
      "purpose": "Dual comparator (using one channel)",
      "specs": {
        "pin_count": 8,
        "pinout": "1:OUT1 2:IN1- 3:IN1+ 4:GND 5:IN2+ 6:IN2- 7:OUT2 8:VCC"
      }
    },
    {
      "ref": "R1",
      "type": "resistor",
      "value": "10kohm",
      "package": "0805",
      "purpose": "Sensor voltage divider (with probe)"
    },
    {
      "ref": "R2",
      "type": "resistor",
      "value": "10kohm",
      "package": "0805",
      "purpose": "Open-collector pull-up for comparator output"
    },
    {
      "ref": "R3",
      "type": "resistor",
      "value": "1kohm",
      "package": "0805",
      "purpose": "Power LED current limiter"
    },
    {
      "ref": "R4",
      "type": "resistor",
      "value": "1kohm",
      "package": "0805",
      "purpose": "Digital output LED current limiter"
    },
    {
      "ref": "RV1",
      "type": "resistor",
      "value": "10kohm",
      "package": "trimmer_3mm",
      "purpose": "Threshold adjustment potentiometer"
    },
    {
      "ref": "C1",
      "type": "capacitor",
      "value": "100nF",
      "package": "0805",
      "purpose": "VCC decoupling",
      "specs": {"voltage_rating": "10V", "type": "ceramic"}
    },
    {
      "ref": "D1",
      "type": "led",
      "value": "red",
      "package": "0805",
      "purpose": "Power indicator LED",
      "specs": {"vf": "2.0V", "if": "5mA"}
    },
    {
      "ref": "D2",
      "type": "led",
      "value": "green",
      "package": "0805",
      "purpose": "Digital output indicator LED",
      "specs": {"vf": "3.2V", "if": "5mA"}
    },
    {
      "ref": "J1",
      "type": "connector",
      "value": "1x4_header",
      "package": "PinHeader_1x4",
      "purpose": "Host connection (VCC, GND, AOUT, DOUT)"
    },
    {
      "ref": "J2",
      "type": "connector",
      "value": "1x2_header",
      "package": "PinHeader_1x2",
      "purpose": "Soil probe connection"
    }
  ],
  "connections": [
    {
      "net_name": "VCC",
      "net_class": "power",
      "pins": ["J1.1", "U1.VCC", "C1.1", "R1.1", "R2.1", "R3.1", "RV1.1"]
    },
    {
      "net_name": "GND",
      "net_class": "ground",
      "pins": ["J1.2", "U1.GND", "C1.2", "RV1.3", "D1.cathode", "D2.cathode"]
    },
    {
      "net_name": "SENSOR_MID",
      "net_class": "signal",
      "pins": ["R1.2", "J2.1", "U1.IN1-", "J1.3"]
    },
    {
      "net_name": "PROBE_GND",
      "net_class": "signal",
      "pins": ["J2.2", "U1.GND"]
    },
    {
      "net_name": "THRESHOLD",
      "net_class": "signal",
      "pins": ["RV1.2", "U1.IN1+"]
    },
    {
      "net_name": "DOUT",
      "net_class": "signal",
      "pins": ["U1.OUT1", "R2.2", "R4.1", "J1.4"]
    },
    {
      "net_name": "LED_DOUT",
      "net_class": "signal",
      "pins": ["R4.2", "D2.anode"]
    },
    {
      "net_name": "PWR_LED",
      "net_class": "signal",
      "pins": ["R3.2", "D1.anode"]
    }
  ],
  "board": {
    "width_mm": 30,
    "height_mm": 20,
    "layers": 2
  },
  "placement_hints": [
    {"ref": "U1", "x_mm": 15, "y_mm": 10},
    {"ref": "J1", "edge": "left"},
    {"ref": "J2", "edge": "right"}
  ]
}
