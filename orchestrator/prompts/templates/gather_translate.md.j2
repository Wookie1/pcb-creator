### Output JSON Schema

You must produce a JSON object with this exact structure:

```json
{
  "project_name": "<lowercase_with_underscores>",
  "description": "<one-line summary of what the circuit does>",
  "power": {
    "voltage": "<e.g. 5V, 3.3V, 12V>",
    "source": "<e.g. 2-pin header connector, USB, battery>"
  },
  "components": [
    {
      "ref": "<designator e.g. J1, R1, D1, U1>",
      "type": "<resistor|capacitor|led|diode|connector|ic|switch|voltage_regulator|...>",
      "value": "<value with units e.g. 150ohm, 100nF, red, LM7805>",
      "package": "<e.g. 0805, SOT-23, PinHeader_1x2>",
      "purpose": "<what this component does in the circuit>",
      "specs": { "<optional key-value specs like vf, if, power, etc.>" }
    }
  ],
  "connections": [
    {
      "net_name": "<descriptive name e.g. VCC, GND, R1_TO_D1>",
      "net_class": "<power|ground|signal>",
      "pins": ["<ref.pin e.g. J1.1, R1.2, D1.anode>"]
    }
  ],
  "packages": "<default package preference e.g. 0805 SMD>",
  "calculations": {
    "<ref>": {
      "formula": "<e.g. (5V - 2.0V) / 20mA>",
      "value": "<result with units>",
      "power": "<power dissipation>",
      "package_ok": true
    }
  },
  "board": {
    "width_mm": "<board width in mm, e.g. 50>",
    "height_mm": "<board height in mm, e.g. 30>",
    "corner_radius_mm": "<optional, default 0>",
    "layers": "<1, 2, or 4, default 2>",
    "outline_type": "<rectangle or dxf>"
  },
  "placement_hints": [
    {
      "ref": "<component ref e.g. J1>",
      "x_mm": "<optional x position>",
      "y_mm": "<optional y position>",
      "rotation_deg": "<0, 90, 180, or 270>",
      "edge": "<top, bottom, left, or right — which board edge>",
      "near": "<optional designator to place near>"
    }
  ],
  "attachments": [
    {
      "filename": "<filename of attached file>",
      "type": "<board_outline|sketch|photo|datasheet|other>",
      "purpose": "<what this file provides>",
      "used_by_steps": [3]
    }
  ],
